# Copy to .env and adjust as needed. Sensible defaults live in settings.py,
# so the app runs with none of these set.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true

# Both upstream services are keyless by default. Point these at your own
# instances (or an OpenRouteService/Mapbox endpoint) if you prefer.
# OSRM_BASE_URL=https://router.project-osrm.org
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# GEOCODER_USER_AGENT=fuelroute/1.0 (you@example.com)

# Vehicle assumptions from the assignment.
# VEHICLE_RANGE_MILES=500
# VEHICLE_MPG=10
# ROUTE_MATCH_BUFFER_MILES=25
